        "datasource": {
          "type": "grafana-azure-monitor-datasource",
          "uid": "$${am_ds}"
        },
        "definition": "",
        "description": "Client ID of the Managed Identity accessing the OpenAI endpoint.\nDisplays ‘UserContext’ when the request is executed under a user context instead of a Managed Identity.",
        "includeAll": true,
        "label": "Managed Identity ClientID",
        "multi": true,
        "name": "MIClientid",
        "options": [],
        "query": {
          "azureLogAnalytics": {
            "dashboardTime": true,
            "mode": "raw",
            "query": "customMetrics\r\n| where tostring(customDimensions[\"Access Type\"]) in (\"UserContext\", \"ManagedIdentity\")\r\n| extend mi_client_id =\r\n    iif(\r\n        tostring(customDimensions[\"Access Type\"]) == \"ManagedIdentity\",\r\n        tostring(customDimensions[\"Client ID\"]),\r\n        \"UserContext\"\r\n    )\r\n| where isnotempty(mi_client_id)\r\n| summarize operationCount=count() by mi_client_id\r\n| sort by operationCount desc\r\n| project mi_client_id",
            "resources": [
              "/subscriptions/$sub/resourceGroups/$rg/providers/microsoft.insights/components/$res"
            ],
            "timeColumn": "timestamp"
          },
          "queryType": "Azure Log Analytics",
          "refId": "A"
        },
        "refresh": 2,
        "regex": "",
        "type": "query"
