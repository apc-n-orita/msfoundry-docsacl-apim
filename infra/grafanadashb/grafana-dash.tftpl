      "pluginVersion": "12.3.1",
      "targets": [
        {
          "azureLogAnalytics": {
            "dashboardTime": true,
            "mode": "raw",
            "query": "let MIClientids = dynamic([$MIClientid]);\ncustomMetrics\n| where tostring(customDimensions[\"Access Type\"]) in (\"UserContext\", \"ManagedIdentity\")\n| extend mi_client_id =\n    iif(\n        tostring(customDimensions[\"Access Type\"]) == \"ManagedIdentity\",\n        tostring(customDimensions[\"Client ID\"]),\n        \"UserContext\"\n    )\n| where isnotempty(mi_client_id)\n| where array_length(MIClientids) > 0\n| where mi_client_id in (MIClientids)\n| evaluate pivot(name, max(value))\n| summarize \n    ['Input Tokens'] = sum(['Prompt Tokens']),\n    ['Output Tokens'] = sum(['Completion Tokens']),\n    ['Total Tokens'] = sum(['Total Tokens'])\n    by bin(timestamp, $__interval)",
            "resources": [
              "/subscriptions/$sub/resourceGroups/$rg/providers/microsoft.insights/components/$res"
