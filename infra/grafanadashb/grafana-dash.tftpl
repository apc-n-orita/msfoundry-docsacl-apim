      },
      "id": 4,
      "interval": "1h",
      "maxDataPoints": 50,
      "options": {
        "legend": {
          "calcs": ["sum"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "hideZeros": false,
          "mode": "multi",
          "sort": "none"
        }
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "azureLogAnalytics": {
            "dashboardTime": true,
            "mode": "raw",
            "query": "let agentNames = dynamic([$agentName]);\ndependencies \n| where operation_Name contains \"user_chat_turn\"\n| extend agent_name = tostring(customDimensions[\"agent_name\"])\n| where isnotempty(agent_name)\n| where array_length(agentNames) > 0\n| where agent_name in (agentNames)\n| extend \n    input_tokens = coalesce(\n        toint(customDimensions[\"tokens.input\"]),\n        toint(customDimensions[\"query_tokens.input\"]) \n            + toint(customDimensions[\"res_tokens.input\"])\n    ),\n    output_tokens = coalesce(\n        toint(customDimensions[\"tokens.output\"]),\n        toint(customDimensions[\"query_tokens.output\"]) \n            + toint(customDimensions[\"res_tokens.output\"])\n    ),\n    total_tokens = coalesce(\n        toint(customDimensions[\"tokens.total\"]),\n        toint(customDimensions[\"query_tokens.total\"]) \n            + toint(customDimensions[\"res_tokens.total\"])\n    )\n| summarize \n    ['Input Tokens'] = sum(input_tokens),\n    ['Output Tokens'] = sum(output_tokens),\n    ['Total Tokens'] = sum(total_tokens)\n    by bin(timestamp, $__interval)",
            "resources": [
              "/subscriptions/$sub/resourceGroups/$rg/providers/microsoft.insights/components/$res"
            ],
            "resultFormat": "time_series",
            "timeColumn": "timestamp"
