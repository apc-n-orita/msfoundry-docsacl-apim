{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Comprehensive monitoring dashboard for AI agent framework performance, tracking operations, token usage, costs, errors, and detailed trace analysis. Monitor agent health, response times, success rates, and resource consumption in real-time.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": 1,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": false,
      "tags": [],
      "targetBlank": true,
      "title": "Doc",
      "tooltip": "Documentation",
      "type": "link",
      "url": "https://aka.ms/amg/dash-doc/af-agent"
    }
  ],
  "panels": [
    {
      "datasource": {
        "type": "grafana-azure-monitor-datasource",
        "uid": "$${am_ds}"
      },
      "description": "Key performance indicators for agent operations including total operations executed, token consumption, and average response time across all agents.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              }
            ]
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Total Operations"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Total Input Tokens"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "purple",
                  "mode": "fixed"
                }
              },
              {
                "id": "unit",
                "value": "short"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Total Output Tokens"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Avg Response Time"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              },
              {
                "id": "unit",
                "value": "s"
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Total Tokens"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "dark-green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 4,
        "w": 21,
        "x": 0,
        "y": 0
      },
      "id": 12,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "percentChangeColorMode": "standard",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "text": {},
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "azureLogAnalytics": {
            "dashboardTime": true,
            "mode": "raw",
            "query": "let agentNames = dynamic([$agentName]);\ndependencies \n| where operation_Name contains \"user_chat_turn\"\n| extend agent_name = tostring(customDimensions[\"agent_name\"])\n| where isnotempty(agent_name)\n| where array_length(agentNames) > 0\n| where agent_name in (agentNames)\n| extend \n    input_tokens = coalesce(\n        toint(customDimensions[\"tokens.input\"]),\n        toint(customDimensions[\"query_tokens.input\"]) \n            + toint(customDimensions[\"res_tokens.input\"])\n    ),\n    output_tokens = coalesce(\n        toint(customDimensions[\"tokens.output\"]),\n        toint(customDimensions[\"query_tokens.output\"]) \n            + toint(customDimensions[\"res_tokens.output\"])\n    ),\n    total_tokens = coalesce(\n        toint(customDimensions[\"tokens.total\"]),\n        toint(customDimensions[\"query_tokens.total\"]) \n            + toint(customDimensions[\"res_tokens.total\"])\n    )\n| summarize \n    ['Total Operations'] = count(),\n    ['Total Input Tokens'] = sum(input_tokens),\n    ['Total Output Tokens'] = sum(output_tokens),\n    ['Total Tokens'] = sum(total_tokens),\n    ['Avg Response Time'] = round(avg(duration) / 1000, 2)",
            "resources": [
              "/subscriptions/$sub/resourceGroups/$rg/providers/microsoft.insights/components/$res"
            ],
            "resultFormat": "time_series",
            "timeColumn": "timestamp"
          },
          "datasource": {
            "type": "grafana-azure-monitor-datasource",
            "uid": "$${am_ds}"
          },
          "queryType": "Azure Log Analytics",
          "refId": "A"
        }
      ],
      "title": "Summary Statistics(Agent)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "grafana-azure-monitor-datasource",
        "uid": "$${am_ds}"
      },
      "description": "Key performance indicators for open ai endpoint operations including total operations executed, token consumption.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              }
            ]
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Total Operations"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Total Input Tokens"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "purple",
                  "mode": "fixed"
                }
              },
              {
                "id": "unit",
                "value": "short"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Total Output Tokens"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Total Tokens"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "dark-green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 4,
        "w": 21,
        "x": 0,
        "y": 4
      },
      "id": 29,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "percentChangeColorMode": "standard",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "text": {},
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "azureLogAnalytics": {
            "dashboardTime": true,
            "mode": "raw",
            "query": "let MIClientids = dynamic([$MIClientid]);\ncustomMetrics\n| where tostring(customDimensions[\"Access Type\"]) in (\"UserContext\", \"ManagedIdentity\")\n| extend mi_client_id =\n    iif(\n        tostring(customDimensions[\"Access Type\"]) == \"ManagedIdentity\",\n        tostring(customDimensions[\"Client ID\"]),\n        \"UserContext\"\n    )\n| extend ip_address = \n    iif(\n        tostring(customDimensions[\"Access Type\"]) == \"ManagedIdentity\",\n        tostring(customDimensions[\"Client ID\"]),\n        tostring(customDimensions[\"Source IP\"])\n    )\n| where isnotempty(mi_client_id) and isnotempty(ip_address)\n| where array_length(MIClientids) > 0\n| where mi_client_id in (MIClientids)\n| evaluate pivot(name, max(value))\n| summarize \n    ['Total Operations'] = dcount(strcat(timestamp, ip_address)),\n    ['Total Input Tokens'] = sum(['Prompt Tokens']),\n    ['Total Output Tokens'] = sum(['Completion Tokens']),\n    ['Total Tokens'] = sum(['Total Tokens'])\n",
            "resources": [
              "/subscriptions/$sub/resourceGroups/$rg/providers/microsoft.insights/components/$res"
            ],
            "resultFormat": "time_series",
            "timeColumn": "timestamp"
          },
          "datasource": {
            "type": "grafana-azure-monitor-datasource",
            "uid": "$${am_ds}"
          },
          "queryType": "Azure Log Analytics",
          "refId": "A"
        }
      ],
      "title": "Summary Statistics(Open AI Endpoint)",
      "type": "stat"
    },
    {
      "collapsed": true,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "id": 20,
      "panels": [
        {
          "datasource": {
            "type": "grafana-azure-monitor-datasource",
            "uid": "$${am_ds}"
          },
          "description": "Time series chart showing average, 95th percentile, and 99th percentile response times for agent operations over time to monitor performance trends and identify latency issues.",
          "fieldConfig": {
            "defaults": {
              "color": {
                "mode": "palette-classic"
              },
              "custom": {
                "axisBorderShow": false,
                "axisCenteredZero": false,
                "axisColorMode": "text",
                "axisLabel": "Duration (seconds)",
                "axisPlacement": "auto",
                "barAlignment": 0,
                "barWidthFactor": 0.6,
                "drawStyle": "line",
                "fillOpacity": 10,
                "gradientMode": "none",
                "hideFrom": {
                  "legend": false,
                  "tooltip": false,
                  "viz": false
                },
                "insertNulls": false,
                "lineInterpolation": "linear",
                "lineWidth": 1,
                "pointSize": 5,
                "scaleDistribution": {
                  "type": "linear"
                },
                "showPoints": "never",
                "showValues": false,
                "spanNulls": false,
                "stacking": {
                  "group": "A",
                  "mode": "none"
                },
                "thresholdsStyle": {
                  "mode": "off"
                }
              },
              "mappings": [],
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "color": "green",
                    "value": 0
                  },
                  {
                    "color": "red",
                    "value": 80
                  }
                ]
              },
              "unit": "s"
            },
            "overrides": []
          },
          "gridPos": {
            "h": 8,
            "w": 9,
            "x": 0,
            "y": 21
          },
          "id": 1,
          "interval": "1h",
          "maxDataPoints": 50,
          "options": {
            "legend": {
              "calcs": ["lastNotNull", "mean"],
              "displayMode": "table",
              "placement": "bottom",
              "showLegend": true
            },
            "tooltip": {
              "hideZeros": false,
              "mode": "multi",
              "sort": "none"
            }
          },
          "pluginVersion": "12.3.1",
          "targets": [
            {
              "azureLogAnalytics": {
                "dashboardTime": true,
                "mode": "raw",
                "query": "let agentNames = dynamic([$agentName]);\ndependencies \n| where operation_Name contains \"user_chat_turn\"\n| extend agent_name = tostring(customDimensions[\"agent_name\"])\n| where isnotempty(agent_name)\n| where array_length(agentNames) > 0\n| where agent_name in (agentNames)\n| summarize \n    avg = avg(duration) / 1000,\n    p95 = percentile(duration, 95) / 1000,\n    p99 = percentile(duration, 99) / 1000\n    by bin(timestamp, $__interval)",
                "resources": [
                  "/subscriptions/$sub/resourceGroups/$rg/providers/microsoft.insights/components/$res"
                ],
                "resultFormat": "time_series",
                "timeColumn": "timestamp"
              },
              "datasource": {
                "type": "grafana-azure-monitor-datasource",
                "uid": "$${am_ds}"
              },
              "queryType": "Azure Log Analytics",
              "refId": "A"
            }
          ],
          "title": "Agent Response Time Trends",
          "type": "timeseries"
        },
        {
          "datasource": {
            "type": "grafana-azure-monitor-datasource",
            "uid": "$${am_ds}"
          },
          "description": "Percentage of successful agent operations displayed as a gauge with color-coded thresholds: red (0-90%), yellow (90-95%), green (95-100%).",
          "fieldConfig": {
            "defaults": {
              "color": {
                "mode": "thresholds"
              },
              "mappings": [],
              "max": 100,
              "min": 0,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "color": "red",
                    "value": 0
                  },
                  {
                    "color": "yellow",
                    "value": 90
                  },
                  {
                    "color": "green",
                    "value": 95
                  }
                ]
              },
              "unit": "percent"
            },
            "overrides": []
          },
          "gridPos": {
            "h": 8,
            "w": 6,
            "x": 9,
            "y": 21
          },
          "id": 2,
          "options": {
            "minVizHeight": 75,
            "minVizWidth": 75,
            "orientation": "auto",
            "reduceOptions": {
              "calcs": ["lastNotNull"],
              "fields": "",
              "values": false
            },
            "showThresholdLabels": false,
            "showThresholdMarkers": true,
            "sizing": "auto",
            "text": {}
          },
          "pluginVersion": "12.3.1",
          "targets": [
            {
              "azureLogAnalytics": {
                "dashboardTime": true,
                "mode": "raw",
                "query": "let agentNames = dynamic([$agentName]);\ndependencies \n| where operation_Name contains \"user_chat_turn\"\n| extend agent_name = tostring(customDimensions[\"agent_name\"])\n| where isnotempty(agent_name)\n| where array_length(agentNames) > 0\n| where agent_name in (agentNames)\n| summarize \n    success_rate = countif(success == \"True\") * 100.0 / count()",
                "resources": [
                  "/subscriptions/$sub/resourceGroups/$rg/providers/microsoft.insights/components/$res"
                ],
                "resultFormat": "time_series",
                "timeColumn": "timestamp"
              },
              "datasource": {
                "type": "grafana-azure-monitor-datasource",
                "uid": "$${am_ds}"
              },
              "queryType": "Azure Log Analytics",
              "refId": "A"
            }
          ],
          "title": "Success Rate",
          "type": "gauge"
        },
        {
          "datasource": {
            "type": "grafana-azure-monitor-datasource",
            "uid": "$${am_ds}"
          },
          "description": "Number of agent operations executed per time interval, displayed as a bar chart to track system utilization and identify peak usage periods.",
          "fieldConfig": {
            "defaults": {
              "color": {
                "mode": "palette-classic"
              },
              "custom": {
                "axisBorderShow": false,
                "axisCenteredZero": false,
                "axisColorMode": "text",
                "axisLabel": "Operations/min",
                "axisPlacement": "auto",
                "barAlignment": 0,
                "barWidthFactor": 0.6,
                "drawStyle": "bars",
                "fillOpacity": 50,
                "gradientMode": "none",
                "hideFrom": {
                  "legend": false,
                  "tooltip": false,
                  "viz": false
                },
                "insertNulls": false,
                "lineInterpolation": "linear",
                "lineWidth": 1,
                "pointSize": 5,
                "scaleDistribution": {
                  "type": "linear"
                },
                "showPoints": "never",
                "showValues": false,
                "spanNulls": false,
                "stacking": {
                  "group": "A",
                  "mode": "none"
                },
                "thresholdsStyle": {
                  "mode": "off"
                }
              },
              "mappings": [],
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "color": "green",
                    "value": 0
                  }
                ]
              },
              "unit": "short"
            },
            "overrides": []
          },
          "gridPos": {
            "h": 8,
            "w": 6,
            "x": 15,
            "y": 21
          },
          "id": 3,
          "interval": "1h",
          "maxDataPoints": 20,
          "options": {
            "legend": {
              "calcs": [],
              "displayMode": "list",
              "placement": "bottom",
              "showLegend": false
            },
            "tooltip": {
              "hideZeros": false,
              "mode": "single",
              "sort": "none"
            }
          },
          "pluginVersion": "12.3.1",
          "targets": [
            {
              "azureLogAnalytics": {
                "dashboardTime": true,
                "mode": "raw",
                "query": "let agentNames = dynamic([$agentName]);\ndependencies \n| where operation_Name contains \"user_chat_turn\"\n| extend agent_name = tostring(customDimensions[\"agent_name\"])\n| where isnotempty(agent_name)\n| where array_length(agentNames) > 0\n| where agent_name in (agentNames)\n| summarize \n    operations_count = count() \n    by bin(timestamp, $__interval)",
                "resources": [
                  "/subscriptions/$sub/resourceGroups/$rg/providers/microsoft.insights/components/$res"
                ],
                "resultFormat": "time_series",
                "timeColumn": "timestamp"
              },
              "datasource": {
                "type": "grafana-azure-monitor-datasource",
                "uid": "$${am_ds}"
              },
              "queryType": "Azure Log Analytics",
              "refId": "A"
            }
          ],
          "title": "Throughput",
          "type": "timeseries"
        }
      ],
      "title": "Performance Monitoring(Agent)",
      "type": "row"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
