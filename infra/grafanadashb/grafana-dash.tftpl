                "mode": "raw",
                "query": "let agentNames = dynamic([$agentName]);\r\ndependencies\r\n| where operation_Name contains \"user_chat_turn\"\r\n| extend Agent = tostring(customDimensions[\"agent_name\"])\r\n| where isnotempty(Agent)\r\n| where array_length(agentNames) > 0\r\n| where Agent in (agentNames)\r\n| extend \r\n    input_tokens = coalesce(\r\n        toint(customDimensions[\"tokens.input\"]),\r\n        toint(customDimensions[\"query_tokens.input\"]) \r\n            + toint(customDimensions[\"res_tokens.input\"])\r\n    ),\r\n    output_tokens = coalesce(\r\n        toint(customDimensions[\"tokens.output\"]),\r\n        toint(customDimensions[\"query_tokens.output\"]) \r\n            + toint(customDimensions[\"res_tokens.output\"])\r\n    ),\r\n    total_tokens = coalesce(\r\n        toint(customDimensions[\"tokens.total\"]),\r\n        toint(customDimensions[\"query_tokens.total\"]) \r\n            + toint(customDimensions[\"res_tokens.total\"])\r\n    )\r\n| project timestamp, Agent, success, duration, input_tokens, output_tokens, total_tokens, TraceId=operation_Id\r\n| order by timestamp desc ",
