    },
    {
      "datasource": {
        "type": "grafana-azure-monitor-datasource",
        "uid": "$${am_ds}"
      },
      "description": "Donut chart showing the distribution of total token consumption (input + output) across different agents, helping identify which agents consume the most resources.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            }
          },
          "mappings": [],
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 9,
        "y": 10
      },
      "id": 5,
      "options": {
        "displayLabels": ["name", "percent"],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
