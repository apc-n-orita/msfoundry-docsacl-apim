            "query": "let agentNames = dynamic([$agentName]);\ndependencies \n| where operation_Name contains \"user_chat_turn\"\n| extend agent_name = tostring(customDimensions[\"agent_name\"])\n| where isnotempty(agent_name)\n| where array_length(agentNames) > 0\n| where agent_name in (agentNames)\n| extend \n    input_tokens = coalesce(\n        toint(customDimensions[\"tokens.input\"]),\n        toint(customDimensions[\"query_tokens.input\"]) \n            + toint(customDimensions[\"res_tokens.input\"])\n    ),\n    output_tokens = coalesce(\n        toint(customDimensions[\"tokens.output\"]),\n        toint(customDimensions[\"query_tokens.output\"]) \n            + toint(customDimensions[\"res_tokens.output\"])\n    )\n| extend \n    // Adjust these rates based on your model pricing (example: GPT-5 mini pricing)\n    input_cost = input_tokens * 0.00000025,   // $0.25 per 1M input tokens\n    output_cost = output_tokens * 0.000002    // $2 per 1M output tokens\n| summarize \n    estimated_cost = sum(input_cost + output_cost)\n    by bin(timestamp, 1d)\n| order by timestamp asc",
